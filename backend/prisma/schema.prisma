// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  company   String?
  phone     String?
  timezone  String?  @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subscription Subscription?
  campaigns    Campaign[]
  integrations Integration[]
  refreshTokens RefreshToken[]
  passwordResets PasswordReset[]
  apiKeys      ApiKey[]
  feeds        Feed[]
  ads          Ad[]
  newCampaigns NewCampaign[]

  @@map("users")
}

// Subscription model
model Subscription {
  id                String   @id @default(cuid())
  userId            String   @unique
  planId            String   // free, starter, professional, enterprise
  status            String   // active, cancelled, past_due, incomplete
  stripeCustomerId  String?
  stripeSubscriptionId String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// Campaign model
model Campaign {
  id            String   @id @default(cuid())
  userId        String
  name          String
  platform      String   // google, microsoft, youtube
  status        String   // draft, active, paused, completed
  budget        Float
  targetAudience Json?   // Store as JSON
  keywords      String[] // Array of keywords
  adGroups      Json?    // Store ad groups as JSON
  settings      Json?    // Campaign settings as JSON
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  performance  CampaignPerformance[]
  adGroups_rel AdGroup[]

  @@map("campaigns")
}

// Ad Group model
model AdGroup {
  id         String   @id @default(cuid())
  campaignId String
  name       String
  keywords   String[]
  ads        Json?    // Store ads as JSON
  settings   Json?    // Ad group settings as JSON
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("ad_groups")
}

// Campaign Performance model
model CampaignPerformance {
  id          String   @id @default(cuid())
  campaignId  String
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Float    @default(0)
  conversions Int      @default(0)
  conversionsValue Float @default(0)
  ctr         Float    @default(0)
  cpc         Float    @default(0)
  cpm         Float    @default(0)
  roas        Float    @default(0)
  createdAt   DateTime @default(now())

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@map("campaign_performance")
}

// Integration model
model Integration {
  id          String   @id @default(cuid())
  userId      String
  platform    String   // google, microsoft, youtube, ga4, gsc
  type        String   // ads, analytics, merchant_center
  credentials Json     // Encrypted credentials
  status      String   // active, inactive, error
  lastSync    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("integrations")
}

// API Key model
model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  name      String
  key       String   @unique
  permissions String[] // Array of permissions
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// Refresh Token model
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// Password Reset model
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// Webhook Event model
model WebhookEvent {
  id        String   @id @default(cuid())
  platform  String   // stripe, google, microsoft, youtube
  eventType String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("webhook_events")
}

// Job Queue model
model Job {
  id        String   @id @default(cuid())
  type      String   // campaign_launch, data_sync, report_generation
  payload   Json
  status    String   // pending, processing, completed, failed
  attempts  Int      @default(0)
  maxAttempts Int    @default(3)
  error     String?
  scheduledAt DateTime?
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime @default(now())

  @@map("jobs")
}

// Notification model
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // alert, report, system
  title     String
  message   String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  @@map("notifications")
}

// Feed model - Product feed management
model Feed {
  id              String   @id @default(cuid())
  userId          String
  name            String
  siteUrl         String
  country         String?
  currency        String?  @default("USD")
  selectorConfig  Json?    // CSS selectors for product extraction
  publicToken     String   @unique @default(cuid())
  lastCrawlStatus String   @default("pending") // pending, running, completed, failed
  lastCrawlAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  Product[]
  ads       Ad[]
  campaigns NewCampaign[]

  @@map("feeds")
}

// Product model - Individual products from feeds
model Product {
  id          String   @id @default(cuid())
  feedId      String
  title       String
  description String?
  price       Float?
  currency    String?
  imageUrl    String?
  link        String
  availability String? // in_stock, out_of_stock, preorder
  brand       String?
  category    String?
  sku         String?
  gtin        String? // Global Trade Item Number
  mpn         String? // Manufacturer Part Number
  condition   String? // new, used, refurbished
  rawData     Json?   // Store original scraped data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  feed Feed @relation(fields: [feedId], references: [id], onDelete: Cascade)
  ads  Ad[]

  @@map("products")
}

// Ad model - Generated ads from products
model Ad {
  id          String   @id @default(cuid())
  userId      String
  feedId      String
  productId   String
  headline    String
  description String
  finalUrl    String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  feed    Feed         @relation(fields: [feedId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  campaigns NewCampaignAd[]

  @@map("ads")
}

// New Campaign model - Updated campaign structure for feed-based campaigns
model NewCampaign {
  id        String   @id @default(cuid())
  userId    String
  feedId    String
  name      String
  channel   String   // google, facebook, linkedin, microsoft
  budget    Float
  currency  String
  country   String
  status    String   @default("draft") // draft, active, paused, completed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  feed  Feed             @relation(fields: [feedId], references: [id], onDelete: Cascade)
  ads   NewCampaignAd[]

  @@map("new_campaigns")
}

// Campaign-Ad relationship model
model NewCampaignAd {
  id         String      @id @default(cuid())
  campaignId String
  adId       String
  createdAt  DateTime    @default(now())

  // Relations
  campaign NewCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ad       Ad          @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([campaignId, adId])
  @@map("new_campaign_ads")
}

