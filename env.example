# ===========================================
# GLOBAL ADS LAUNCH & OPTIMIZATION - ENV CONFIG
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000/api

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL connection string
# Format: postgresql://username:password@localhost:5432/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/global_ads_db

# ===========================================
# REDIS CONFIGURATION
# ===========================================
# Redis connection string
# Format: redis://username:password@localhost:6379
REDIS_URL=redis://localhost:6379

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Generate secure random strings for production
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here-change-in-production

# JWT expiration times (in seconds)
JWT_EXPIRES_IN=900  # 15 minutes
JWT_REFRESH_EXPIRES_IN=604800  # 7 days

# ===========================================
# STRIPE CONFIGURATION
# ===========================================
# Get these from your Stripe dashboard
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe price IDs for different plans
STRIPE_STARTER_PRICE_ID=price_starter_plan_id
STRIPE_PROFESSIONAL_PRICE_ID=price_professional_plan_id
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_plan_id

# ===========================================
# GOOGLE ADS API CONFIGURATION
# ===========================================
# Get these from Google Cloud Console
GOOGLE_ADS_CLIENT_ID=your_google_ads_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_ads_client_secret
GOOGLE_ADS_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
GOOGLE_ADS_CUSTOMER_ID=your_google_ads_customer_id

# ===========================================
# GOOGLE MERCHANT CENTER API
# ===========================================
GOOGLE_MERCHANT_CENTER_CLIENT_ID=your_merchant_center_client_id
GOOGLE_MERCHANT_CENTER_CLIENT_SECRET=your_merchant_center_client_secret
GOOGLE_MERCHANT_CENTER_REDIRECT_URI=http://localhost:5000/api/auth/merchant/callback

# ===========================================
# MICROSOFT ADS API CONFIGURATION
# ===========================================
# Get these from Microsoft Advertising Developer Center
MICROSOFT_ADS_CLIENT_ID=your_microsoft_ads_client_id
MICROSOFT_ADS_CLIENT_SECRET=your_microsoft_ads_client_secret
MICROSOFT_ADS_REDIRECT_URI=http://localhost:5000/api/auth/microsoft/callback
MICROSOFT_ADS_CUSTOMER_ID=your_microsoft_ads_customer_id

# ===========================================
# YOUTUBE API CONFIGURATION
# ===========================================
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:5000/api/auth/youtube/callback

# ===========================================
# GOOGLE ANALYTICS 4 (GA4) CONFIGURATION
# ===========================================
GA4_CLIENT_ID=your_ga4_client_id
GA4_CLIENT_SECRET=your_ga4_client_secret
GA4_REDIRECT_URI=http://localhost:5000/api/auth/ga4/callback
GA4_PROPERTY_ID=your_ga4_property_id

# ===========================================
# GOOGLE SEARCH CONSOLE CONFIGURATION
# ===========================================
GSC_CLIENT_ID=your_gsc_client_id
GSC_CLIENT_SECRET=your_gsc_client_secret
GSC_REDIRECT_URI=http://localhost:5000/api/auth/gsc/callback

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
# SMTP settings for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Email templates
EMAIL_FROM_NAME=Global Ads Launch
EMAIL_FROM_ADDRESS=noreply@globaladslaunch.com

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================
# Maximum file size for uploads (in bytes)
MAX_FILE_SIZE=10485760  # 10MB

# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/csv,application/vnd.ms-excel

# Upload directory
UPLOAD_DIR=uploads

# ===========================================
# RATE LIMITING CONFIGURATION
# ===========================================
# Rate limiting settings
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # 100 requests per window

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log file directory
LOG_DIR=logs

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Session secret for secure sessions
SESSION_SECRET=your-session-secret-here

# Encryption key for sensitive data
ENCRYPTION_KEY=your-32-character-encryption-key

# ===========================================
# MONITORING & ANALYTICS
# ===========================================
# Sentry DSN for error tracking
SENTRY_DSN=your_sentry_dsn_here

# Google Analytics tracking ID
GA_TRACKING_ID=your_ga_tracking_id

# ===========================================
# CPANEL DEPLOYMENT SETTINGS
# ===========================================
# These settings are for cPanel deployment
CPANEL_DOMAIN=yourdomain.com
CPANEL_SUBDOMAIN=api.yourdomain.com
CPANEL_SSL_CERT_PATH=/path/to/ssl/certificate

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
# Enable/disable features in development
ENABLE_SWAGGER=true
ENABLE_DEBUG_ROUTES=true
MOCK_EXTERNAL_APIS=false

# ===========================================
# PRODUCTION SETTINGS
# ===========================================
# Production-specific settings
ENABLE_COMPRESSION=true
ENABLE_CACHING=true
CACHE_TTL=3600  # 1 hour

# ===========================================
# WEBHOOK CONFIGURATION
# ===========================================
# Webhook endpoints for external services
WEBHOOK_BASE_URL=https://api.yourdomain.com/api/webhooks

# ===========================================
# BACKUP CONFIGURATION
# ===========================================
# Database backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# ===========================================
# FEATURE FLAGS
# ===========================================
# Enable/disable features
FEATURE_GOOGLE_ADS=true
FEATURE_MICROSOFT_ADS=true
FEATURE_YOUTUBE_ADS=true
FEATURE_GA4_INTEGRATION=true
FEATURE_GSC_INTEGRATION=true
FEATURE_AUTO_OPTIMIZATION=true
FEATURE_B2B_WIZARD=true
FEATURE_ALERTS=true

